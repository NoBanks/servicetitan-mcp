{
  "mcpServers": {
    "servicetitan": {
      "command": "servicetitan-mcp",
      "env": {
        "SERVICETITAN_CLIENT_ID": "your-oauth-client-id",
        "SERVICETITAN_CLIENT_SECRET": "your-oauth-client-secret",
        "SERVICETITAN_APP_KEY": "your-app-key",
        "SERVICETITAN_TENANT_ID": "your-tenant-id"
      }
    }
  }
}
